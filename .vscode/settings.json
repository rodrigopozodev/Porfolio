{
    "IDX.aI.enableInlineCompletion": true,
    "IDX.aI.enableCodebaseIndexing": true,
    // Desactiva validación pesada para CSS/SCSS/LESS (reduce alertas del editor)
    "css.validate": false,
    "scss.validate": false,
    "less.validate": false,
    // Ignora avisos comunes del linter CSS para un archivo con Tailwind/PostCSS
    "css.lint.unknownAtRules": "ignore",
    "css.lint.unknownProperties": "ignore",
    "css.lint.vendorPrefix": "ignore",
    "css.lint.boxModel": "ignore",
    // Usa el lenguaje CSS nativo para coloreado de sintaxis
    "files.associations": {
        "*.css": "css",
        "*.scss": "scss",
        "*.less": "less"
    },
    // Opcional: autocompletado de Emmet con clases Tailwind
    "tailwindCSS.emmetCompletions": true,
    // Garantiza resaltado semántico
    "editor.semanticHighlighting.enabled": true
}